set -o errexit
set -o nounset
set -o errtrace
set -o pipefail

parse_configuration() {
  shopt -s nullglob
  local i
  for i in /etc/age-api.d/*.conf /usr/local/etc/age-api.d/*.conf; do
    bash -n "$i"
    source "$i"
  done

  api_file_local="~/.age-api/age-bracket.conf"
  if test -f "$api_file_local"; then
    bash -n "$api_file_local"
    source "$api_file_local"
  fi
}

parse_configuration

printf '%s\n' "$age_bracket"
